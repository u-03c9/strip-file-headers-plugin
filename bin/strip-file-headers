#!/usr/bin/env php
<?php

declare(strict_types=1);

use Project\StripFileHeaders\HeaderStripper;
use Project\StripFileHeaders\StripperConfig;

$options = parseOptions($argv);
if ($options['help']) {
    echo helpText();
    exit(0);
}

$autoloadCandidates = [
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../../autoload.php',
];

$autoloaded = false;
foreach ($autoloadCandidates as $autoload) {
    if (is_file($autoload)) {
        require $autoload;
        $autoloaded = true;
        break;
    }
}

if (!$autoloaded) {
    $sourceDir = __DIR__ . '/../src';
    if (is_file($sourceDir . '/StripResult.php')) {
        require $sourceDir . '/StripResult.php';
        require $sourceDir . '/StripperConfig.php';
        require $sourceDir . '/HeaderStripper.php';
        $autoloaded = true;
    }
}

if (!$autoloaded) {
    fwrite(STDERR, "Unable to locate Composer autoload file or local source classes.\n");
    exit(1);
}

$config = StripperConfig::fromCliOptions([
    'root' => $options['root'],
    'scope' => $options['scope'],
    'scopes' => $options['scopes'],
    'dirs' => $options['dirs'],
    'extensions' => $options['extensions'],
    'exclude' => $options['exclude'],
]);

$stripper = new HeaderStripper();
$result = $stripper->strip(
    $config,
    $options['dry-run'],
    $options['verbose'] || $options['dry-run'],
    static function (string $message): void {
        echo $message . PHP_EOL;
    }
);

printf(
    "[strip-file-headers] scanned %d file(s); %s %d file(s).\n",
    $result->scanned,
    $options['dry-run'] ? 'would strip' : 'stripped',
    $result->changed
);

/**
 * @param list<string> $argv
 * @return array{dry-run: bool, verbose: bool, help: bool, root: string, scope: string, scopes: list<string>, dirs: list<string>, extensions: list<string>, exclude: list<string>}
 */
function parseOptions(array $argv): array
{
    $options = [
        'dry-run' => false,
        'verbose' => false,
        'help' => false,
        'root' => getcwd() ?: '.',
        'scope' => 'vendor',
        'scopes' => [],
        'dirs' => [],
        'extensions' => [],
        'exclude' => [],
    ];

    foreach (array_slice($argv, 1) as $arg) {
        if ($arg === '--dry-run') {
            $options['dry-run'] = true;
            continue;
        }

        if ($arg === '--verbose' || $arg === '-v') {
            $options['verbose'] = true;
            continue;
        }

        if ($arg === '--help' || $arg === '-h') {
            $options['help'] = true;
            continue;
        }

        if (strpos($arg, '--root=') === 0) {
            $options['root'] = substr($arg, 7);
            continue;
        }

        if (strpos($arg, '--scope=') === 0) {
            $scope = normalizeScope(substr($arg, 8));
            if ($scope === null) {
                fwrite(STDERR, "Invalid scope. Use app, vendor, or both.\n\n");
                fwrite(STDERR, helpText());
                exit(1);
            }

            $options['scope'] = $scope;
            continue;
        }

        if (strpos($arg, '--add-scope=') === 0) {
            $scope = normalizeScope(substr($arg, 12));
            if ($scope === null) {
                fwrite(STDERR, "Invalid scope. Use app, vendor, or both.\n\n");
                fwrite(STDERR, helpText());
                exit(1);
            }

            $options['scopes'][] = $scope;
            continue;
        }

        if ($arg === '--app-only') {
            $options['scope'] = 'app';
            continue;
        }

        if ($arg === '--vendor-only') {
            $options['scope'] = 'vendor';
            continue;
        }

        if ($arg === '--both') {
            $options['scope'] = 'both';
            continue;
        }

        if (strpos($arg, '--dir=') === 0) {
            $options['dirs'][] = substr($arg, 6);
            continue;
        }

        if (strpos($arg, '--ext=') === 0) {
            $options['extensions'][] = ltrim(substr($arg, 6), '.');
            continue;
        }

        if (strpos($arg, '--exclude=') === 0) {
            $options['exclude'][] = substr($arg, 10);
            continue;
        }

        fwrite(STDERR, "Unknown option: {$arg}\n\n");
        fwrite(STDERR, helpText());
        exit(1);
    }

    if ($options['dirs'] === []) {
        $options['dirs'] = dirsForScope($options['scope']);
    }

    if ($options['extensions'] === []) {
        $options['extensions'] = ['php', 'phtml', 'xml'];
    }

    return $options;
}

function normalizeScope(string $scope): ?string
{
    $scope = strtolower(trim($scope));

    if ($scope === 'app' || $scope === 'app-only') {
        return 'app';
    }

    if ($scope === 'vendor' || $scope === 'vendor-only') {
        return 'vendor';
    }

    if ($scope === 'both') {
        return 'both';
    }

    return null;
}

/**
 * @return list<string>
 */
function dirsForScope(string $scope): array
{
    if ($scope === 'app') {
        return ['app'];
    }

    if ($scope === 'vendor') {
        return ['vendor'];
    }

    return ['app', 'vendor'];
}

function helpText(): string
{
    return <<<'HELP'
Usage:
  strip-file-headers [options]

Options:
  --dry-run          List files that would change without writing them.
  --verbose, -v      Print every stripped file.
  --root=PATH        Project root. Defaults to the current working directory.
  --scope=SCOPE      Scan app, vendor, or both. Defaults to vendor.
  --add-scope=SCOPE  Add app, vendor, or both. May be passed more than once.
  --app-only         Shortcut for --scope=app.
  --vendor-only      Shortcut for --scope=vendor.
  --both             Shortcut for --scope=both.
  --dir=PATH         Directory to scan. May be passed more than once.
  --ext=EXT          Extension to scan. May be passed more than once.
  --exclude=PATH     Relative path to skip. May be passed more than once.
  --help, -h         Show this help.

Defaults:
  --scope=vendor --ext=php --ext=phtml --ext=xml

Passing --dir overrides --scope. Passing --add-scope adds to either set.

HELP;
}
