{
    "name": "u-03c9/strip-file-headers-plugin",
    "description": "Composer plugin that strips leading file header comments after install and update.",
    "type": "composer-plugin",
    "license": "proprietary",
    "require": {
        "php": ">=7.4",
        "composer-plugin-api": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Project\\StripFileHeaders\\": "src/"
        }
    },
    "bin": [
        "bin/strip-file-headers"
    ],
    "extra": {
        "class": "Project\\StripFileHeaders\\ComposerPlugin"
    }
}
